{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openboot.dev/schemas/auth.json",
  "title": "CLI Device Auth Flow",
  "description": "Request/response contracts for the CLI device authentication flow.",
  "$defs": {
    "startResponse": {
      "description": "Response from POST /api/auth/cli/start",
      "type": "object",
      "required": ["code_id", "code"],
      "properties": {
        "code_id": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 }
      }
    },
    "pollResponse": {
      "description": "Response from GET /api/auth/cli/poll?code_id=...",
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "expired", "used"]
        },
        "token": {
          "type": "string",
          "pattern": "^obt_",
          "description": "Present only when status is 'approved'"
        },
        "username": { "type": "string" },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
