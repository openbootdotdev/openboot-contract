{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openboot.dev/schemas/packages.json",
  "title": "PackageCatalog",
  "description": "Response from GET /api/packages — full package metadata catalog.",
  "type": "object",
  "required": ["packages"],
  "properties": {
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "desc", "category", "type", "installer"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "desc": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["essential", "development", "productivity", "optional"]
          },
          "type": {
            "type": "string",
            "enum": ["cli", "gui", "language", "devops", "database"]
          },
          "installer": {
            "type": "string",
            "enum": ["formula", "cask", "npm"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
